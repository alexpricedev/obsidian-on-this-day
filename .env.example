# ── Vault source ──────────────────────────────────────────────
# Choose ONE mode.
#
# (A) Local mode — read a vault folder already on this machine.
VAULT_ROOT_PATH="/absolute/path/to/folder/containing/your/vault"
#
# (B) GitHub mode — clone a private vault repo into a cache dir.
# GITHUB_REPO="owner/repo"
# GITHUB_TOKEN="github_pat_..."          # read-only Contents scope
# VAULT_CACHE_DIR="./.vault-cache"       # where the clone is kept (optional)

# ── Vault ─────────────────────────────────────────────────────
# The vault folder inside the source above. Also used as the
# Obsidian vault name when building obsidian:// deep links.
# (For a single-vault source, set this to the vault's own name.)
VAULT_NAME="My Journal"

# ── Email delivery (Resend) ───────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="On This Day <onthisday@yourdomain.com>"
EMAIL_TO="you@example.com"

# ── Note links (optional) ─────────────────────────────────────
# By default notes link with obsidian:// deep links. Many webmail clients
# (Proton Mail, Gmail) strip custom-protocol links, so they won't be clickable
# there. Set this to the URL of the https redirect page (docs/index.html, e.g.
# hosted on GitHub Pages) to make links work in every client. Leave unset if you
# only read in Apple Mail. See the README.
# REDIRECT_BASE_URL="https://your-name.github.io/obsidian-on-this-day/"
